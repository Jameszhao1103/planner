# Copy this file to .env.local for local development.

# Runtime mode
PLANNER_PROVIDER=mock
PLANNER_COMMAND_TRANSLATOR=rules
PLANNER_STORAGE_MODE=file

# Local file persistence (used when PLANNER_STORAGE_MODE=file)
PLANNER_DATA_DIR=.data/trips

# Optional local-only debug routes (/api/debug/* and Reset sample trip)
PLANNER_ENABLE_DEBUG_ROUTES=0

# Observability and cache
PLANNER_LOG_REQUESTS=1
PLANNER_LOG_LEVEL=info
PLANNER_CACHE_TTL_MS=300000
PLANNER_PLACE_DETAILS_CACHE_TTL_MS=1800000

# Google server-side key for Places / Routes
GOOGLE_MAPS_API_KEY=

# Google browser key for Maps JavaScript API
# Restrict this key by HTTP referrer (for example localhost and your production domain).
GOOGLE_MAPS_BROWSER_API_KEY=

# OpenAI command planner
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
